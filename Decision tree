import pandas
from sklearn.model_selection import train_test_split
from sklearn.tree import DecisionTreeRegressor
from sklearn.metrics import mean_absolute_error


# load the cleaned data set
dataset = pandas.read_csv("cleaned_car_details_dataset.csv")
dataset = dataset.drop(columns=["Model"])

Features = dataset.drop(columns=["Price"])   # Features
Target = dataset["Price"]                  # Target

#converts text into values

Features = pandas.get_dummies(Features, drop_first = True)
Features_train, Features_test, Target_train, Target_test = train_test_split(Features, Target,test_size=0.3,random_state=42)
model = DecisionTreeRegressor(random_state=42,max_depth=10) # max depth to reduce overfitting
model.fit(Features_train, Target_train)
# Make predictions
Target_pred = model.predict(Features_test)

# Evaluate
mae = mean_absolute_error(Target_test, Target_pred)
sse = ((Target_test - Target_pred) ** 2).sum()


print("Decision Tree Results")
print("----------------------")
print("MAE:", round(mae, 2))
print("SSE:", round(sse, 2))

# Features importances
importances = pandas.Series(model.feature_importances_, index=Features.columns)
importances_sorted = importances.sort_values(ascending=False)

# Strongest Features
strongest = importances_sorted.head(1)
print("\nStrongest Features:")
print(strongest)

# Top 5 Features
top5 = importances_sorted.head(5)
print("\nTop 5 Features:")
print(top5)

# Weakest Features
weakest = importances_sorted.tail(1)
print("\nWeakest Features:")
print(weakest)
